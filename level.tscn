[node name="DelilahOrca" parent="." unique_id=1879044386 instance=ExtResource("7_8b0r0")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 10.890306, 0, 11.736488)
text = "You found another orca!
GLADIS: Get in loser. We're going YachtSinking.
DELILAH: Schweet.
GLADIS: Any advice, Delilah?
DELILAH: Try to ram the yacht very very hard.
Your ram damage has increased."

[node name="PhilOrca" parent="." unique_id=1538291848 instance=ExtResource("7_8b0r0")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 7.412863, 0, 11.526627)
text = "You found another orca!
GLADIS: Phil, I need to slow these yachts down.
PHIL: You could try biting the rudder off.
GLADIS: How would I do that?
PHIL: Get behind the yacht. When you hear the rudder splashing, press 1."

[node name="ClaraOrca" parent="." unique_id=1831192771 instance=ExtResource("7_8b0r0")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 3.285677, 0, 11.526627)
text = "You found another orca!
GLADIS: Hey, Clara. We’re gonna sink another yacht.
CLARA: Pod goals.
GLADIS: This is tiring work. Got any fish?
CLARA: Here, have a tuna.
Your health has increased by 5."

[node name="MaryOrca" parent="." unique_id=1955721028 instance=ExtResource("7_8b0r0")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -1.8425093, 0, 11.526627)
text = "You found another orca!
GLADIS: The crew of those yachts have guns!
MARY: Oh, we can deal with that.
GLADIS: How’s that, Mary?
MARY: As you approach the boat, press 2 to swim under it. The wave you make will wash over the boat, stopping the gunners for a while."

[node name="HerbieOrca" parent="." unique_id=454965760 instance=ExtResource("7_8b0r0")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -7.389141, 0, 11.526627)
text = "You found another orca!
GLADIS: I wish I was as fast as you, Herbie!
HERBIE: It’s all in the tail.
Your speed has increased."

[node name="GregOrca" parent="." unique_id=2034037131 instance=ExtResource("7_8b0r0")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -12.389141, 0, 11.526627)
text = "You found another orca!
GLADIS: They’ve put mines in the water!
GREG: The arrogance. The sea is our domain!
GLADIS: Damn straight.
GREG: Okay, hear me out. Press 3 to slap your tail on the surface of the water, safely detonating any nearby mines."

